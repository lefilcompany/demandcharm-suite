{
  "version": 1,
  "sdk_version": "0.20.0",
  "path": "/functions/v1/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://erxhxmetrvkigjwxchbj.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "soma-mcp",
      "version": "0.1.0",
      "title": "SoMA — Gestão de Demandas"
    },
    "tools": [
      {
        "name": "whoami",
        "title": "Who am I",
        "description": "Return the signed-in SoMA user's profile (id, name, email).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "list_boards",
        "title": "List boards",
        "description": "List SoMA boards the signed-in user has access to (via RLS).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 50,
              "description": "Max boards to return."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_my_demands",
        "title": "List my demands",
        "description": "List demands where the signed-in user is a responsible or follower assignee. Optionally filter by board.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "board_id": {
              "type": "string",
              "format": "uuid",
              "description": "Optional board UUID to filter by."
            },
            "include_archived": {
              "type": "boolean",
              "default": false,
              "description": "Include archived demands."
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 50
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "search_demands",
        "title": "Search demands",
        "description": "Search SoMA demands the signed-in user can see (via RLS) by title/description substring.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "minLength": 1,
              "description": "Text to match in demand title or description."
            },
            "board_id": {
              "type": "string",
              "format": "uuid"
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 50,
              "default": 20
            }
          },
          "required": [
            "query"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "get_demand",
        "title": "Get demand",
        "description": "Fetch a single SoMA demand by id, including its assignees.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "demand_id": {
              "type": "string",
              "format": "uuid",
              "description": "Demand UUID."
            }
          },
          "required": [
            "demand_id"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "create_demand",
        "title": "Create demand",
        "description": "Create a new SoMA demand on a board as the signed-in user. Resolves the board's team, uses the first active status of the board when status_id is omitted, and assigns the caller as the responsible when assignee_user_id is omitted. Respects RLS and plan limits.",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": false,
          "idempotentHint": false,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "board_id": {
              "type": "string",
              "format": "uuid",
              "description": "Board UUID where the demand will be created."
            },
            "title": {
              "type": "string",
              "minLength": 1,
              "maxLength": 200,
              "description": "Demand title."
            },
            "description": {
              "type": "string",
              "description": "Optional demand description."
            },
            "priority": {
              "type": "string",
              "enum": [
                "baixa",
                "média",
                "alta",
                "urgente"
              ],
              "default": "média",
              "description": "Priority: baixa | média | alta | urgente."
            },
            "due_date": {
              "type": "string",
              "format": "date-time",
              "description": "Optional ISO-8601 due date (with timezone)."
            },
            "status_id": {
              "type": "string",
              "format": "uuid",
              "description": "Optional board status UUID. Defaults to the first active status on the board."
            },
            "service_id": {
              "type": "string",
              "format": "uuid",
              "description": "Optional service UUID."
            },
            "assignee_user_id": {
              "type": "string",
              "format": "uuid",
              "description": "Optional responsible user UUID. Defaults to the signed-in user."
            }
          },
          "required": [
            "board_id",
            "title"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      }
    ]
  }
}
